{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "3",
  "tasks": {
    "postinstall": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^postinstall"]
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "deploy": {
      "dependsOn": ["build", "test", "lint"]
    },
    "test": {},
    "delete": {},
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    }
  }
}
