{
  "name": "@markflowy/i18n",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "rimraf dist && node esbuild.config.mjs && tsc --emitDeclarationOnly && node scripts/flatten-dts.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "i18next": "23.16.8",
    "react-i18next": "15.7.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "esbuild": "^0.28.1",
    "react": "^19.2.0",
    "rimraf": "^6.1.0",
    "typescript": "^5.7.3"
  }
}
