{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MarkFlowy",
  "version": "0.55.4",
  "identifier": "com.drl990114.markflowy",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "plugins": {
    "cli": {
      "description": "MarkFlowy - AI-Native Markdown Editor",
      "longDescription": "A modern, lightweight Markdown editor with built-in AI capabilities.\n\nUsage: markflowy [COMMAND] [OPTIONS]\n       mf [COMMAND] [OPTIONS]\n\nYou can create a symlink or alias 'mf' to 'markflowy' for shorter invocation.",
      "subcommands": {
        "open": {
          "description": "Open a file or folder in MarkFlowy",
          "args": [
            {
              "name": "path",
              "description": "Path to the file or folder to open",
              "index": 1,
              "takesValue": true,
              "required": true
            }
          ]
        },
        "help": {
          "description": "Print this help message"
        },
        "version": {
          "description": "Print version information"
        }
      }
    },
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "http://api.upgrade.toolsetlink.com/v1/tauri/upgrade?tauriKey=xpn68m4j5qU0Y1rfDYFHaA&versionName={{current_version}}&appointVersionName=&devModelKey=&devKey=&target={{target}}&arch={{arch}}",
        "https://drl990114.github.io/MarkFlowy/install.json",
        "https://github.com/drl990114/MarkFlowy/releases/latest/download/install.json"
      ],
      "dangerousInsecureTransportProtocol": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3M0ZEQUYyOEMyNjVCNTIKUldSU1d5YU04dG8vaDFTemY1RVdrTWNNTUdvMlQ3K05nMnJSQzc5cldQZXM4N2N1ejF3UnJsM1kK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "copyright": "Copyright (c) 2023-present drl990114",
    "shortDescription": "AI-Powered Markdown Editor",
    "longDescription": "MarkFlowy is a modern, lightweight Markdown editor with built-in AI capabilities. Features include AI-powered translation, summarization, multiple editing modes (WYSIWYG and source code), custom themes, keyboard shortcuts, and support for multiple file formats. Built with Tauri for optimal performance.",
    "fileAssociations": [
      {
        "ext": [
          ".md",
          ".markdown",
          ".json",
          ".txt"
        ],
        "name": "Text Document",
        "description": "Text Document",
        "mimeType": "text/plain",
        "role": "Editor"
      }
    ],
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": [
          "en-US"
        ]
      }
    },
    "macOS": {
      "entitlements": "./entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "**/*"
          ]
        }
      },
      "csp": null
    }
  }
}
